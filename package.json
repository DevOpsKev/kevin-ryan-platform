{
  "name": "kevinryan-platform",
  "private": true,
  "scripts": {
    "build": "pnpm --filter './sites/*' --if-present build",
    "lint": "pnpm --filter './sites/*' --if-present lint",
    "dev:kevinryan-io": "pnpm --filter kevinryan-io dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "markdownlint-cli": "^0.47.0",
    "tsc-files": "^1.1.4"
  },
  "lint-staged": {
    "sites/kevinryan-io/**/*.{ts,tsx}": [
      "eslint --fix -c sites/kevinryan-io/eslint.config.mjs",
      "tsc-files --noEmit"
    ],
    "*.{tf,tfvars}": [
      "terraform fmt -check"
    ],
    "*.{yaml,yml}": [
      "yamllint -s"
    ],
    "*.md": [
      "markdownlint"
    ],
    "Dockerfile*": [
      "hadolint"
    ]
  }
}